rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /coaches/{coachId} {
      allow read, write: if request.auth != null && request.auth.uid == coachId;
    }
    
    match /coaches/{coachId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == coachId;
    }
  }
}
